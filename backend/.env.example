# Env is loaded from the monorepo root `.env` first, then `backend/.env` (overrides).
# Copy this file to `backend/.env` and/or keep shared keys in the repo root `.env`.

NODE_ENV=development
APP_NAME=Prawaas
AUTH_TOKEN_SECRET=replace-with-a-long-random-secret
AUTH_TOKEN_EXPIRES_IN=30d

PUBLIC_API_BASE_URL=http://localhost:3000

# Local database example
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=prawaas_db_dev

# Set true only when the DB user is allowed to create databases.
# For most cloud/shared DBs, keep this false or omit it.
DB_AUTO_CREATE=true

DB_CONNECTION_LIMIT=10

ELASTIC_EMAIL_API_KEY=
FROM_EMAIL=

INTERAKT_API_KEY=
INTERAKT_API_URL=
INTERAKT_TEMPLATE_LANGUAGE=en
INTERAKT_OTP_TEMPLATE_NAME=otp_verification
INTERAKT_CALLBACK_DATA=otp_test

MASTER_OTP=
MASTER_USER_EMAIL=
MASTER_USER_MOBILE=
