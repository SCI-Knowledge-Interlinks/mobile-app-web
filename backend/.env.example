NODE_ENV=development
APP_NAME=Prawaas
AUTH_TOKEN_SECRET=replace-with-a-long-random-secret
AUTH_TOKEN_EXPIRES_IN=30d
#PUBLIC_API_BASE_URL=http://localhost:3000
PUBLIC_API_BASE_URL= http://192.168.0.101:3000 #http://172.20.10.8:3000 #

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=

# Optional. If omitted:
# - development uses prawaas_db_dev
# - production uses prawaas_db_prod
DB_NAME=prawaas_db_dev

DB_CONNECTION_LIMIT=10

ELASTIC_EMAIL_API_KEY=
FROM_EMAIL=

INTERAKT_API_KEY=
INTERAKT_API_URL=
INTERAKT_TEMPLATE_LANGUAGE=en
INTERAKT_OTP_TEMPLATE_NAME=otp_verification
INTERAKT_CALLBACK_DATA=otp_test
