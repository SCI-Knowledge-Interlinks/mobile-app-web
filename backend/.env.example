# Env is loaded from the monorepo root `.env` first, then `backend/.env` (overrides).
# Copy this file to `backend/.env` and/or keep shared keys in the repo root `.env`.

NODE_ENV=development
APP_NAME=Prawaas
AUTH_TOKEN_SECRET=replace-with-a-long-random-secret
AUTH_TOKEN_EXPIRES_IN=30d

#PUBLIC_API_BASE_URL=https://mediumorchid-beaver-865559.hostingersite.com
PUBLIC_API_BASE_URL=http://localhost:3000

# Local database example
DB_PROFILE=local

DB_LOCAL_HOST=localhost
DB_LOCAL_PORT=3306
DB_LOCAL_USER=root
DB_LOCAL_PASSWORD=
DB_LOCAL_NAME=prawaas_db_dev

# Production DB over the internet: your host must allow connections from your app’s public IP
# (hPanel → Databases → Remote MySQL, or equivalent). Otherwise you’ll see
# Access denied for user '…'@'YOUR_PUBLIC_IP'.
DB_PROD_HOST=
DB_PROD_PORT=3306
DB_PROD_USER=
DB_PROD_PASSWORD=
DB_PROD_NAME=prawaas_db_prod
# Optional: remote MySQL TLS. Try true first; use insecure only if the host requires it (weakens cert verification).
# DB_PROD_SSL=true
# DB_PROD_SSL=insecure

# Set true only when the DB user is allowed to create databases.
# For most cloud/shared DBs, keep this false or omit it.
DB_AUTO_CREATE=true

DB_CONNECTION_LIMIT=10

# Emergency only: start HTTP even if MySQL init fails (most routes will error).
# START_WITHOUT_DB=true

ELASTIC_EMAIL_API_KEY=
FROM_EMAIL=

INTERAKT_API_KEY=
INTERAKT_API_URL=
INTERAKT_TEMPLATE_LANGUAGE=en
INTERAKT_OTP_TEMPLATE_NAME=otp_verification
INTERAKT_CALLBACK_DATA=otp_test

MASTER_OTP=
MASTER_USER_EMAIL=
MASTER_USER_MOBILE=

# Firebase Admin SDK (prawaas-650d0) — place key at backend/secrets/firebase-service-account.json
# FIREBASE_SERVICE_ACCOUNT_PATH=./secrets/firebase-service-account.json
