{
  "name": "prawaas",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start --dev-client",
    "start:clear": "expo start --clear",
    "android": "expo run:android",
    "android:dev": "EAS_BUILD_PROFILE=development npx expo prebuild --platform android && npx expo run:android --device",
    "build:apk:dev": "EAS_BUILD_PROFILE=development npx expo prebuild --platform android --clean && cd android && ./gradlew assembleDebug -PreactNativeArchitectures=arm64-v8a",
    "web": "expo start --web",
    "build": "npx expo export --platform web --output-dir ../dist",
    "build:web": "npx expo export --platform web --output-dir ../dist",
    "ios": "expo run:ios",
    "eas:build:android:dev": "eas build --profile development --platform android",
    "eas:build:android:preview": "EAS_NO_VCS=1 eas build --profile preview --platform android",
    "build:apk": "EAS_BUILD_PROFILE=preview npx expo prebuild --platform android --clean && cd android && ./gradlew assembleRelease -PreactNativeArchitectures=arm64-v8a",
    "build:apk:install": "npm run build:apk && adb install -r android/app/build/outputs/apk/release/app-release.apk",
    "eas:build:ios:dev": "eas build --profile development --platform ios"
  },
  "dependencies": {
    "@expo-google-fonts/roboto": "^0.4.3",
    "@expo-google-fonts/roboto-condensed": "^0.4.2",
    "@expo/vector-icons": "^15.1.1",
    "babel-preset-expo": "~54.0.10",
    "expo": "~54.0.35",
    "expo-build-properties": "~1.0.10",
    "expo-camera": "~17.0.10",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.21",
    "expo-device": "~8.0.10",
    "expo-font": "~14.0.12",
    "expo-image-picker": "~17.0.11",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.12",
    "expo-notifications": "~0.32.17",
    "expo-router": "~6.0.24",
    "expo-secure-store": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "firebase": "^12.15.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.5.1",
    "socket.io-client": "^4.8.3"
  },
  "private": true,
  "devDependencies": {
    "http-proxy-middleware": "^4.1.1",
    "react-native-svg-transformer": "^1.5.3"
  }
}
