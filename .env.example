# Production API
EXPO_PUBLIC_API_BASE_URL=https://azure-cassowary-742969.hostingersite.com
EXPO_PUBLIC_EVENT_ID=1

# Web browser dev (`npm run web` on localhost) uses http://localhost:3000 automatically.
# For production API on web, set EXPO_PUBLIC_API_BASE_URL below — Metro proxies API calls to avoid CORS.
# Keep the backend running only when using the local API URL.
# Local backend — keep localhost; Android emulator rewrites to 10.0.2.2 automatically.
# EXPO_PUBLIC_API_BASE_URL=http://localhost:3000

# Physical Android device on same Wi‑Fi only (use your computer's LAN IP):
# EXPO_PUBLIC_API_BASE_URL=http://192.168.x.x:3000

EXPO_PUBLIC_APP_NAME=Prawaas

# Public exhibitor list (Prawaas 2026)
