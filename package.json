{
  "name": "prawaas-project",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "concurrently \"npm run backend\" \"npm run frontend\"",

    "backend": "npm --prefix backend run dev",
    "frontend": "npm --prefix frontend start",

    "android": "npm --prefix frontend run android",
    "ios": "npm --prefix frontend run ios",
    "web": "npm --prefix frontend run web",

    "backend:start": "npm --prefix backend start",

    "start:android": "concurrently \"npm run backend\" \"npm run android\"",
    "start:ios": "concurrently \"npm run backend\" \"npm run ios\"",
    "start:web": "concurrently \"npm run backend\" \"npm run web\"",

    "build:web": "npm --prefix frontend run build:web"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
